# Valid environments are production or development
APP_ENV=development

# Development variables
DEV_DB_URL=./flizix_dev.db
DEV_JWT_SECRET=you_super_dev_secret

# Production variables
DB_URL=./flizix.db
# Consider use a random secret for sign JWT tokens, you can use "openssl rand -base64 32"
JWT_SECRET=your_super_prod_secret

APP_PORT=8080