# Valid environments are production or development
APP_ENV=development

# Development variables
DEV_DB_URL=./flizix_dev.db
DEV_JWT_SECRET=you_super_dev_secret

# Production variables
DB_URL=./flizix.db
# Consider use a random secret for sign JWT tokens, you can use "openssl rand -base64 32"
JWT_SECRET=your_super_prod_secret

APP_PORT=8080

# Telegram BOT token for communication and verification
TELEGRAM_BOT_TOKEN=7231076069:AAGMJKYtCNJ-nWk4f7hSrM1fernhiwegohine

# CORS policies, crucial for development and also if different domains on production
ENABLE_CORS=true # Set to true if CORS policies apply, default is false
ALLOWED_ORIGINS=http://localhost:5173 # You can set an array various origins with comma separation like: http://adomain,http:bdomain